{
  "manifest_version": 3,
  "name": "Browser MCP Export",
  "version": "2.0",
  "description": "Export cookies, browser signature, and IndexedDB for browser MCP containers",
  "permissions": ["cookies", "downloads", "scripting", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  }
}
